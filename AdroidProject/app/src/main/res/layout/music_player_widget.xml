<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Local player ready"
        android:textColor="#B3B3B3"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="No local track selected"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Open the app to choose a sample song"
        android:textColor="#B3B3B3"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_previous"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Previous track"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:background="@android:color/transparent"
            android:contentDescription="Play playback"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@android:drawable/ic_media_play"
            android:tint="#1DB954" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@android:color/transparent"
            android:contentDescription="Next track"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@android:drawable/ic_media_next"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/widget_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawablePadding="4dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="Search"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
